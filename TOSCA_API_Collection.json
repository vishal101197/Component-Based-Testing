		{
			"name": "Status",
			"item": [
				{
					"name": "Check status",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// === Check status ===",
									"console.clear();",
									"console.log(\"=== Check status ===\");",
									"",
									"let res;",
									"try {",
									"  res = pm.response.json();",
									"} catch (e) {",
									"  pm.test(\"Response is JSON\", function(){ pm.expect.fail(\"Non-JSON response\"); });",
									"  postman.setNextRequest(null);",
									"  return;",
									"}",
									"",
									"// Normalize status from various fields",
									"let rawStatus = (res.Status || res.status || res.state || res.State || \"\").toString();",
									"let status = rawStatus.trim().toUpperCase();",
									"console.log(\"Current status:\", status || \"<empty>\");",
									"",
									"// Ensure we have an executionId",
									"const execId = pm.collectionVariables.get(\"ExecutionId\");",
									"pm.test(\"ExecutionId available\", function(){",
									"  pm.expect(execId, \"Missing collection var ExecutionId\").to.be.a(\"string\").and.not.empty;",
									"});",
									"",
									"// Poll counters and limits - READ FROM VARIABLES (not hardcoded)",
									"const maxAttempts = parseInt(pm.environment.get(\"maxPollAttempts\") || pm.collectionVariables.get(\"maxPollAttempts\") || \"100\", 10);",
									"const delayMs = parseInt(pm.environment.get(\"pollIntervalMs\") || pm.collectionVariables.get(\"pollIntervalMs\") || \"15000\", 10);",
									"let attempt = parseInt(pm.collectionVariables.get(\"pollAttempt\") || \"0\", 10);",
									"attempt += 1;",
									"pm.collectionVariables.set(\"pollAttempt\", attempt);",
									"console.log(`Attempt ${attempt}/${maxAttempts} (delay ${delayMs}ms)`);",
									"",
									"// Exceeded attempts",
									"if (attempt > maxAttempts) {",
									"  pm.test(\"Polling did not complete in time\", function(){",
									"    pm.expect.fail(`Exceeded maxPollAttempts (${maxAttempts}). Last status: ${status}`);",
									"  });",
									"  postman.setNextRequest(null);",
									"  return;",
									"}",
									"",
									"// Control flow based on status",
									"if (status === \"INPROGRESS\" || status === \"QUEUED\" || status === \"PENDING\") {",
									"  pm.test(\"Still in progress\", function(){",
									"    pm.expect([\"INPROGRESS\",\"QUEUED\",\"PENDING\"]).to.include(status);",
									"  });",
									"  setTimeout(function(){",
									"    postman.setNextRequest(\"Check status\");",
									"  }, delayMs);",
									"  return;",
									"}",
									"",
									"if (status === \"COMPLETED\" || status === \"SUCCESS\") {",
									"  pm.collectionVariables.set(\"statusDesired\", \"Completed\");",
									"  pm.test(\"Execution completed\", function(){",
									"    pm.expect(status).to.be.oneOf([\"COMPLETED\",\"SUCCESS\"]);",
									"  });",
									"  // Do not setNextRequest; allow run order to continue",
									"  return;",
									"}",
									"",
									"// Terminal failure states",
									"if ([\"FAILED\",\"ERROR\",\"ERRORED\",\"CANCELED\",\"CANCELLED\",\"TIMEOUT\"].includes(status)) {",
									"  pm.test(\"Execution failed\", function(){",
									"    pm.expect.fail(`Terminal status: ${status}`);",
									"  });",
									"  postman.setNextRequest(null);",
									"  return;",
									"}",
									"",
									"// Unknown status",
									"pm.test(\"Unknown status encountered\", function(){",
									"  pm.expect.fail(`Unknown status '${rawStatus}'`);",
									"});",
									"postman.setNextRequest(null);"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
